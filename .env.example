# Django Email/SMTP Configuration
# Copy this file to .env and fill in your credentials

# Email Backend (use: django.core.mail.backends.smtp.EmailBackend for production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Gmail SMTP Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

# Your Gmail email address
EMAIL_HOST_USER=Samuelonyango932@gmail.com

# Your Gmail App Password (NOT your regular password - see setup guide below)
EMAIL_HOST_PASSWORD=your_16_character_app_password_here

# Default sender email
DEFAULT_FROM_EMAIL=Samuelonyango932@gmail.com

# Admin email to receive notifications
SHOP_ADMIN_EMAIL=Samuelonyango932@gmail.com

# ============================================
# IMPORTANT: Gmail App Password Setup Guide
# ============================================
#
# Gmail does NOT allow regular account passwords over SMTP.
# You MUST create an App Password instead:
#
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. If "App passwords" option doesn't appear:
#    - Go to Security settings: https://myaccount.google.com/security
#    - Enable 2-Step Verification first
#    - Then return to App passwords
# 3. Select "Mail" and "Windows Computer"
# 4. Google will generate a 16-character password
# 5. Copy that password and paste it as EMAIL_HOST_PASSWORD above
#
# Example App Password Format: abcd efgh ijkl mnop (16 characters, spaces optional)
#
# ============================================
